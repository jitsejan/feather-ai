# Confluence API credentials (official namespace)
[sources.atlassian_confluence]
username = "name@example.com"
password = "atlassian-api-token"

# Legacy namespace still supported as fallback:
# [sources.confluence]

# DuckDB or MotherDuck connection
[destination.duckdb]
credentials = "md:database_name?token=your-motherduck-token"
